<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:backgroundTint="@color/reportHeaderColor"
    android:layout_marginBottom="16dp"
    android:padding="32dp"
    app:cardCornerRadius="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"


        android:padding="16dp">

        <TextView
            android:id="@+id/tvPregunta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pregunta:"
            android:textStyle="italic"
            android:textAppearance="?android:attr/textAppearanceMedium" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <ImageButton
                android:id="@+id/btnCalificacion0"
                android:layout_width="10dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:padding="12dp"
                android:backgroundTint="@color/reportHeaderColor"
                android:scaleType="fitCenter"
                android:src="@drawable/imagen_calificacion_0" />

            <ImageButton
                android:id="@+id/btnCalificacion5"
                android:layout_width="10dp"
                android:layout_height="60dp"
                android:backgroundTint="@color/reportHeaderColor"
                android:layout_weight="1"
                android:padding="12dp"
                android:scaleType="fitCenter"
                android:src="@drawable/imagen_calificacion_5" />

            <ImageButton
                android:id="@+id/btnCalificacion10"
                android:layout_width="10dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:backgroundTint="@color/reportHeaderColor"
                android:padding="12dp"
                android:scaleType="fitCenter"
                android:src="@drawable/imagen_calificacion_10" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
